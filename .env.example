# --- Server ---
PORT=8080
LOG_LEVEL=info

# --- MCP transport ---
# Comma-separated extra Host header values to accept. localhost / 127.0.0.1
# / [::1] (any port) are always allowed; add your production hostname here.
# Example: MCP_ALLOWED_HOSTS=mcp.example.com,mcp.staging.example.com
MCP_ALLOWED_HOSTS=

# --- Auth / quotas ---
# Choose store: "memory" for dev, "upstash" for prod.
TOKEN_STORE=memory
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Tracking response cache ---
# "memory" (default) = in-process TTLCache, per-pod, lost on restart.
# "upstash" = Upstash-Redis-backed; cache entries shared across pods
# and survive pod churn up to the TTL. Reuses UPSTASH_REDIS_REST_URL /
# _TOKEN above. Opt-in independently of TOKEN_STORE.
RESPONSE_CACHE_BACKEND=memory
RESPONSE_CACHE_TTL_SECONDS=60

# --- DSV / Schenker upstream ---
# Default targets the post-DSV-acquisition host. The legacy
# `www.dbschenker.com` 302-redirects to mydsv.dsv.com; override only behind
# a corporate proxy or when pointing tests at a fixture server.
SCHENKER_BASE_URL=https://mydsv.dsv.com
SCHENKER_TIMEOUT_MS=10000

# --- Runtime feature flags ---
# Enable the Playwright-based SPA-scrape fallback (recommended for any
# deployment on a rate-limited egress IP; the JSON path 429s often).
# Requires the [fallback] extra: `uv sync --extra fallback` +
# `playwright install chromium`. Without the extra the fallback fails
# fast with a clean `upstream_unavailable` error.
DB2ST_HTML_FALLBACK=

# Dev-only escape hatch: skip the bearer-auth middleware entirely.
# DO NOT set in production. Useful when wiring this MCP into a host
# that handles auth at its own layer (e.g., a private Knative cluster
# behind an authenticating reverse proxy).
DB2ST_AUTH_DISABLED=
